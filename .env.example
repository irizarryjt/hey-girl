# Copy to .env and fill in. The key stays server-side; the browser never sees it.
ANTHROPIC_API_KEY=sk-ant-...
# Optional overrides
PORT=8787
CLAUDE_MODEL=claude-sonnet-4-6

# Private preview gate: set SITE_PASSWORD to lock the whole site behind a login.
# Leave both unset for open access. SITE_USER defaults to "hey".
# SITE_USER=hey
# SITE_PASSWORD=choose-a-shared-password

# Supabase (accounts + saved data). Leave unset to stay in local-only mode.
# Browser-exposed (safe): the project URL and the anon/public key.
# VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...your-anon-public-key...
# Server-only SECRET — used for the guest-link endpoint. Never prefix with VITE_.
# SUPABASE_URL=https://YOURPROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
