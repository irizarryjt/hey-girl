# Copy to .env and fill in. The key stays server-side; the browser never sees it.
ANTHROPIC_API_KEY=sk-ant-...
# Optional overrides
PORT=8787
CLAUDE_MODEL=claude-sonnet-4-6

# Private preview gate: set SITE_PASSWORD to lock the whole site behind a login.
# Leave both unset for open access. SITE_USER defaults to "hey".
# SITE_USER=hey
# SITE_PASSWORD=choose-a-shared-password
